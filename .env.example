# Solomon — Environment Variables
# Copy this file to .env and fill in the values
# Never commit .env to git!

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=solomon.settings.dev

# Database (PostgreSQL)
DATABASE_URL=postgres://solomon:solomon@localhost:5432/solomon

# Email (for notifications — optional in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Localization
LANGUAGE_CODE=cs
TIME_ZONE=Europe/Prague

# App version (set by CI/CD or manually)
APP_VERSION=0.1.0
